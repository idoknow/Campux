generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  active
  paused
  archived
}

enum TenantRole {
  submitter
  reviewer
  admin
}

enum SystemRole {
  system_operator
}

enum PostStatus {
  pending_approval
  approved
  rejected
  cancelled
  publishing
  partially_failed
  failed
  published
  pending_recall
  recalled
}

enum PublishAttemptStatus {
  queued
  running
  succeeded
  failed
  skipped
}

model Tenant {
  id             String             @id @default(uuid())
  slug           String             @unique
  host           String?            @unique
  name           String
  status         TenantStatus       @default(active)
  themeColor     String             @default("#e0574f")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  memberships    TenantMembership[]
  sessions       AccountSession[]
  metadata       TenantMetadata[]
  posts          Post[]
  botAccounts    BotAccount[]
  publishTargets PublishTarget[]
  auditLogs      AuditLog[]
}

model User {
  id          String             @id @default(uuid())
  qqUin       BigInt             @unique
  displayName String?
  passwordHash String
  isTestAccount Boolean           @default(false)
  systemRole  SystemRole?
  createdAt   DateTime           @default(now())
  memberships TenantMembership[]
  posts       Post[]
  sessions    AccountSession[]
  auditLogs   AuditLog[]
}

model AccountSession {
  id               String   @id @default(uuid())
  userId           String
  tokenHash        String   @unique
  selectedTenantId String?
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedTenant   Tenant?  @relation(fields: [selectedTenantId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([expiresAt])
}

model TenantMembership {
  id        String     @id @default(uuid())
  tenantId  String
  userId    String
  role      TenantRole @default(submitter)
  createdAt DateTime   @default(now())
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
}

model TenantMetadata {
  id        String   @id @default(uuid())
  tenantId  String
  key       String
  value     Json
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

model Post {
  id              String           @id @default(uuid())
  tenantId        String
  authorId        String
  displayId       Int
  text            String
  images          Json             @default("[]")
  anonymous       Boolean          @default(false)
  status          PostStatus       @default(pending_approval)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author          User             @relation(fields: [authorId], references: [id])
  logs            PostLog[]
  publishAttempts PublishAttempt[]

  @@unique([tenantId, displayId])
  @@index([tenantId, status, createdAt])
}

model PostLog {
  id        String     @id @default(uuid())
  tenantId  String
  postId    String
  actorId   String?
  oldStatus PostStatus?
  newStatus PostStatus
  comment   String
  createdAt DateTime   @default(now())
  post      Post       @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([tenantId, postId, createdAt])
}

model BotAccount {
  id             String          @id @default(uuid())
  tenantId       String
  qqUin          BigInt
  displayName    String
  enabled        Boolean         @default(true)
  reviewGroupId  String?
  publishTextTemplate Json        @default("{\"includePostId\":true,\"includeAuthorMention\":false,\"includeLinks\":false,\"customText\":\"\"}")
  lastSeenAt     DateTime?
  createdAt      DateTime        @default(now())
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  publishTargets PublishTarget[]
  sessions       BotSession[]

  @@unique([tenantId, qqUin])
}

model BotSession {
  id           String     @id @default(uuid())
  botAccountId String
  type         String     @default("qzone")
  domain       String     @default("user.qzone.qq.com")
  cookies      Json
  rawCookies   String?
  refreshedAt  DateTime   @default(now())
  expiresAt    DateTime?
  healthStatus String     @default("unchecked")
  healthCheckedAt DateTime?
  healthMessage String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  botAccount   BotAccount @relation(fields: [botAccountId], references: [id], onDelete: Cascade)

  @@unique([botAccountId, type, domain])
  @@index([botAccountId, refreshedAt])
}

model PublishTarget {
  id                  String           @id @default(uuid())
  tenantId            String
  botAccountId        String
  type                String           @default("qzone")
  displayName         String
  enabled             Boolean          @default(true)
  required            Boolean          @default(true)
  publishDelaySeconds Int              @default(300)
  failurePolicy       String           @default("block_post")
  qzoneRefreshMode    String           @default("protocol")
  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  botAccount          BotAccount       @relation(fields: [botAccountId], references: [id], onDelete: Cascade)
  attempts            PublishAttempt[]

  @@index([tenantId, enabled])
}

model PublishAttempt {
  id              String               @id @default(uuid())
  tenantId        String
  postId          String
  publishTargetId String
  status          PublishAttemptStatus @default(queued)
  attempt         Int                  @default(0)
  lastError       String?
  verbose         Json?
  nextRunAt       DateTime?
  externalId      String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  post            Post                 @relation(fields: [postId], references: [id], onDelete: Cascade)
  publishTarget   PublishTarget        @relation(fields: [publishTargetId], references: [id], onDelete: Cascade)

  @@unique([postId, publishTargetId])
  @@index([tenantId, status, nextRunAt])
}

model BanRecord {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String
  operatorId String?
  comment    String
  startsAt   DateTime @default(now())
  endsAt     DateTime
  createdAt  DateTime @default(now())

  @@index([tenantId, userId, endsAt])
  @@index([tenantId, endsAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?
  actorId    String?
  action     String
  targetType String
  targetId   String?
  detail     Json?
  createdAt  DateTime @default(now())
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}
