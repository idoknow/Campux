NODE_ENV="development"
DATABASE_URL="postgresql://campux:***@localhost:5432/campux_next"
CAMPUX_SERVER_HOST="0.0.0.0"
CAMPUX_SERVER_PORT="8989"
CAMPUX_WEB_ORIGIN="http://localhost:5180"
CAMPUX_WEB_DIST_DIR="apps/web/dist"

# 生产必填：用于加密存储 Bot session cookies。生产环境缺失会启动失败。
# 生成示例：openssl rand -hex 32
CAMPUX_BOT_SESSION_SECRET="replace-with-a-long-random-secret-in-production"

# 设为 true / 1 可跳过启动时的自动数据库迁移（默认会自动迁移）。
CAMPUX_SKIP_AUTO_MIGRATE="false"

# 容器内 Chromium 路径，用于 QQ 空间渲染图。容器镜像建议设为 /usr/bin/chromium-browser。
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=""

# 多租户官方服务可选：自助开墙时自动分配 ${slug}.${CAMPUX_TENANT_DOMAIN_SUFFIX}
# 并通过 Cloudflare API 创建 CNAME。API Token 至少需要 Zone Read + DNS Write。
# CAMPUX_TENANT_DOMAIN_SUFFIX="campux.top"
# CAMPUX_TENANT_DOMAIN_TARGET="app.campux.top"
# CAMPUX_CLOUDFLARE_API_TOKEN="replace-with-cloudflare-api-token"
# 可选：不填时会按 suffix 查询 Zone。
# CAMPUX_CLOUDFLARE_ZONE_ID=""
# 可选：默认 proxied=true、ttl=1（Cloudflare 自动 TTL）。
# CAMPUX_TENANT_DOMAIN_PROXIED="true"
# CAMPUX_TENANT_DOMAIN_TTL="1"

S3_ENDPOINT="http://localhost:9000"
S3_REGION="auto"
S3_BUCKET="campux-next"
S3_ACCESS_KEY_ID="campux"
S3_SECRET_ACCESS_KEY="campux-secret"
S3_PUBLIC_BASE_URL="http://localhost:9000/campux-next"

# 邮件（可选）：配置后运营管理员注册验证码通过 Resend 发送。
# 未配置时不发送邮件，验证码会直接显示在注册接口的响应里（适合自用/无邮件部署）。
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Campux <noreply@campux.top>"
